# ── VehicleAI Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it with real secrets.

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1            # increase for production (e.g. 2-4)

# ── Model ──────────────────────────────────────────────────────────────────────
# Absolute or relative path to the model weights file.
# Relative paths are resolved from the project root.
MODEL_PATH=best.pt
FALLBACK_MODEL_PATH=yolov8n.pt

# ── Inference ──────────────────────────────────────────────────────────────────
CONFIDENCE=0.35      # default confidence threshold (0.05 – 0.95)
IOU=0.45             # NMS IoU threshold
IMG_SIZE=640         # inference resolution (pixels)

# ── Storage ────────────────────────────────────────────────────────────────────
# Where processed output videos are written.
OUTPUT_VIDEO_DIR=backend/outputs
